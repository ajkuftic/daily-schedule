<%- include('_head', { title: 'Pick Calendars' }) %>

<h1>Pick Google Calendars</h1>
<p class="subtitle">Choose which calendars to include in your daily newsletter.</p>

<form method="POST" action="/setup/calendars/google-pick" class="form">
  <div class="card">
    <h3>Available Calendars</h3>
    <p class="muted">Check the calendars to include. Mark reminder calendars if their events should always display in your home timezone (e.g. recurring alarms).</p>

    <table class="table">
      <thead>
        <tr>
          <th>Include</th>
          <th>Calendar</th>
          <th>Reminder Calendar</th>
        </tr>
      </thead>
      <tbody>
        <% for (const cal of calendars) { %>
          <tr>
            <td><input type="checkbox" name="calendar_ids" value="<%= cal.id %>" <%= cal.primary ? 'checked' : '' %>></td>
            <td><%= cal.summary %> <% if (cal.primary) { %><span class="badge">primary</span><% } %></td>
            <td><input type="checkbox" name="reminder_ids" value="<%= cal.id %>"></td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>

  <div class="form-actions">
    <button type="submit" class="btn btn-primary">Save &amp; Continue</button>
    <a href="/setup/calendars" class="btn btn-ghost">Cancel</a>
  </div>
</form>

<%- include('_foot') %>
