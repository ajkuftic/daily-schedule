<%- include('_head', { title: 'Webhooks' }) %>

<h1>Webhooks</h1>
<p class="subtitle">Trigger the newsletter from other apps, or notify a service after each send.</p>

<% if (flash.saved)  { %><div class="alert alert-success">Saved.</div><% } %>
<% if (flash.error)  { %><div class="alert alert-error">Error: <%= flash.error %></div><% } %>

<!-- ── INCOMING ───────────────────────────────────────────── -->
<div class="card" style="margin-bottom:24px;">
  <h3>Incoming — Trigger a send</h3>
  <p class="muted">POST to this URL from any automation tool (Home Assistant, Zapier, Make, Shortcuts…) to trigger an immediate newsletter send.</p>

  <% if (config.webhook_secret) { %>
    <div class="form-group" style="margin-top:16px;">
      <label>Webhook URL</label>
      <div style="display:flex;gap:8px;align-items:center;">
        <code class="webhook-url"><%= protocol %>://<%= host %>/webhook/<%= config.webhook_secret %></code>
        <button type="button" class="btn btn-sm btn-ghost"
          onclick="navigator.clipboard.writeText('<%= protocol %>://<%= host %>/webhook/<%= config.webhook_secret %>');this.textContent='Copied!';setTimeout(()=>this.textContent='Copy',2000)">Copy</button>
      </div>
      <p class="field-hint">Method: <code>POST</code> &nbsp;·&nbsp; No body or auth header needed — the secret is in the URL.</p>
    </div>
  <% } else { %>
    <p class="muted" style="margin-top:12px;">No secret generated yet. Click below to create one.</p>
  <% } %>

  <form method="POST" action="/setup/webhooks" style="margin-top:16px;">
    <input type="hidden" name="action" value="regenerate">
    <button type="submit" class="btn btn-ghost">
      <%= config.webhook_secret ? 'Regenerate Secret' : 'Generate Secret' %>
    </button>
  </form>

  <% if (config.webhook_secret) { %>
    <div class="callout" style="margin-top:16px;">
      <strong>Example:</strong><br>
      <code>curl -X POST "<%= protocol %>://<%= host %>/webhook/<%= config.webhook_secret %>"</code>
    </div>
  <% } %>
</div>

<!-- ── OUTGOING ───────────────────────────────────────────── -->
<div class="card">
  <h3>Outgoing — Notify after each send</h3>
  <p class="muted">After each successful newsletter send, Daily Schedule will POST a JSON payload to this URL. Leave blank to disable.</p>

  <form method="POST" action="/setup/webhooks" class="form" style="margin-top:16px;">
    <input type="hidden" name="action" value="save-outgoing">
    <div class="form-group">
      <label>Notify URL <span class="hint">(Slack incoming webhook, Make scenario, etc.)</span></label>
      <input type="url" name="webhook_outgoing_url"
        value="<%= config.webhook_outgoing_url || '' %>"
        placeholder="https://hooks.slack.com/services/…">
    </div>
    <div class="callout" style="margin-bottom:16px;">
      <strong>Payload sent:</strong><br>
      <code>{"date":"2026-03-21","dateStr":"Saturday, March 21, 2026","status":"success","subject":"Daily Kuftic – …","sentTo":"family@example.com"}</code>
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
    <% if (config.webhook_outgoing_url) { %>
      <span class="field-hint" style="margin-left:12px;">Currently set to: <strong><%= config.webhook_outgoing_url %></strong></span>
    <% } %>
  </form>
</div>

<div class="form-actions" style="margin-top:24px;">
  <a href="/setup" class="btn btn-ghost">Back to Dashboard</a>
</div>

<style>
.webhook-url {
  font-family: monospace;
  font-size: 13px;
  background: #f1ede4;
  padding: 6px 10px;
  border-radius: 4px;
  word-break: break-all;
  flex: 1;
}
.callout {
  margin-top: 14px;
  padding: 12px 16px;
  background: #eff6ff;
  border: 1px solid #bfdbfe;
  border-radius: var(--radius);
  font-size: 13px;
  color: #1e40af;
  line-height: 1.55;
}
.callout code {
  font-family: monospace;
  font-size: 12px;
  word-break: break-all;
}
</style>

<%- include('_foot') %>
