<%- include('_head', { title: 'Calendars' }) %>

<h1>Calendar Sources</h1>
<p class="subtitle">Add one or more calendar accounts to pull events from.</p>

<% if (flash.saved === 'blurbs')  { %><div class="alert alert-success">Blurbs setting updated.</div>
<% } else if (flash.saved === 'edited') { %><div class="alert alert-success">Calendar updated.</div>
<% } else if (flash.saved)    { %><div class="alert alert-success">Calendar added.</div><% } %>
<% if (flash.deleted) { %><div class="alert alert-success">Calendar removed.</div><% } %>
<% if (flash.error)   { %><div class="alert alert-error">Error: <%= flash.error %></div><% } %>

<% if (accounts.length > 0) { %>
  <div class="card" style="margin-bottom:24px;">
    <h3>Connected Calendars</h3>
    <table class="table">
      <thead><tr><th>Name</th><th>Provider</th><th>Reminder?</th><th>Blurbs</th><th></th></tr></thead>
      <tbody>
        <% for (const a of accounts) { %>
          <tr>
            <td>
              <div><strong><%= a.name %></strong></div>
              <% if (a.provider === 'ics' && a.credentials && a.credentials.url) { %>
                <div class="hint" style="margin-top:3px;font-size:12px;word-break:break-all;"><%= a.credentials.url %></div>
              <% } else if (a.provider === 'caldav' && a.credentials && a.credentials.serverUrl) { %>
                <div class="hint" style="margin-top:3px;font-size:12px;"><%= a.credentials.serverUrl %></div>
              <% } %>
            </td>
            <td><span class="badge badge-<%= a.provider %>"><%= a.provider %></span></td>
            <td><%= a.is_reminder ? 'Yes' : 'No' %></td>
            <td>
              <form method="POST" action="/setup/calendars/<%= a.id %>/blurbs" style="display:inline;">
                <input type="hidden" name="blurbs_enabled" value="0">
                <input type="checkbox" name="blurbs_enabled" value="1" title="Enable AI blurbs for this calendar"
                  <%= a.blurbs_enabled !== 0 ? 'checked' : '' %>
                  onchange="this.form.submit()">
              </form>
            </td>
            <td style="white-space:nowrap;">
              <a href="/setup/calendars/<%= a.id %>/edit" class="btn btn-sm btn-ghost">Edit</a>
              <form method="POST" action="/setup/calendars/delete/<%= a.id %>" style="display:inline;">
                <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Remove this calendar?')">Remove</button>
              </form>
            </td>
          </tr>
        <% } %>
      </tbody>
    </table>
    <p class="hint" style="margin-top:8px;">Blurbs column controls whether Claude generates event descriptions for each calendar. Requires AI Blurbs to be enabled globally in <a href="/setup/blurbs">AI Blurbs settings</a>.</p>
  </div>
<% } %>

<div class="provider-grid">

  <!-- CalDAV -->
  <div class="card">
    <h3>CalDAV</h3>
    <p class="muted">Apple iCloud, Fastmail, Nextcloud, or any CalDAV server.</p>
    <details>
      <summary class="btn btn-ghost">Add CalDAV account</summary>
      <form method="POST" action="/setup/calendars/caldav" class="form" style="margin-top:16px;">
        <div class="form-group">
          <label>Display Name</label>
          <input type="text" name="name" placeholder="iCloud" required>
        </div>
        <div class="form-group">
          <label>Server URL</label>
          <input type="text" name="server_url" placeholder="https://caldav.icloud.com" required>
        </div>
        <div class="form-group">
          <label>Username</label>
          <input type="text" name="username" placeholder="user@icloud.com" required>
        </div>
        <div class="form-group">
          <label>Password / App-specific password</label>
          <input type="password" name="password" required>
        </div>
        <div class="form-group">
          <label><input type="checkbox" name="is_reminder"> Reminder calendar (always show in home timezone)</label>
        </div>
        <button type="submit" class="btn btn-primary">Add</button>
      </form>
    </details>
  </div>

  <!-- ICS Feed -->
  <div class="card">
    <h3>ICS / iCal Feed</h3>
    <p class="muted">Any public .ics URL — holidays, sports schedules, Google Calendar share links, etc.</p>
    <details>
      <summary class="btn btn-ghost">Add ICS feed</summary>
      <form method="POST" action="/setup/calendars/ics" class="form" style="margin-top:16px;">
        <div class="form-group">
          <label>Display Name</label>
          <input type="text" name="name" placeholder="US Holidays" required>
        </div>
        <div class="form-group">
          <label>ICS URL</label>
          <input type="url" name="url" placeholder="https://..." required>
        </div>
        <div class="form-group">
          <label><input type="checkbox" name="is_reminder"> Reminder calendar</label>
        </div>
        <button type="submit" class="btn btn-primary">Add</button>
      </form>
    </details>
  </div>

</div>

<div class="form-actions" style="margin-top:24px;">
  <a href="/setup/email" class="btn btn-ghost">Next: Email &rarr;</a>
</div>

<%- include('_foot') %>
