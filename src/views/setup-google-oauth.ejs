<%- include('_head', { title: 'Google OAuth Setup' }) %>

<div style="max-width:680px;">

<div class="page-header">
  <div>
    <h1>Set Up Google OAuth</h1>
    <p class="subtitle">One-time setup — takes about 10 minutes. Do this once and all Google Calendar and Gmail connections will work.</p>
  </div>
</div>

<% if (flash.saved) { %>
  <div class="alert alert-success">
    Credentials saved. <a href="<%= returnTo %>">Back to setup &rarr;</a>
  </div>
<% } %>
<% if (flash.error) { %>
  <div class="alert alert-error"><%= flash.error %></div>
<% } %>
<% if (config.google_client_id) { %>
  <div class="alert alert-info">
    Google OAuth is already configured. You can update the credentials below if needed.
  </div>
<% } %>

<!-- ── STEP 1 ─────────────────────────────────────────────── -->
<div class="walkthrough-step">
  <div class="step-number">1</div>
  <div class="step-body">
    <h3>Create a Google Cloud project</h3>
    <ol>
      <li>Open <strong><a href="https://console.cloud.google.com/projectcreate" target="_blank" rel="noopener">console.cloud.google.com/projectcreate</a></strong></li>
      <li>Give it any name (e.g. <em>Daily Schedule</em>) and click <strong>Create</strong></li>
      <li>Make sure the new project is selected in the top dropdown before continuing</li>
    </ol>
  </div>
</div>

<!-- ── STEP 2 ─────────────────────────────────────────────── -->
<div class="walkthrough-step">
  <div class="step-number">2</div>
  <div class="step-body">
    <h3>Enable the APIs you need</h3>
    <p>Click each link below — it opens the right page for your project. Click <strong>Enable</strong> on each.</p>
    <div class="api-links">
      <a href="https://console.cloud.google.com/apis/library/calendar-json.googleapis.com" target="_blank" rel="noopener" class="api-link">
        <span class="api-icon">📅</span>
        <span>
          <strong>Google Calendar API</strong><br>
          <small>Required for reading calendar events</small>
        </span>
        <span class="api-arrow">&rarr;</span>
      </a>
      <a href="https://console.cloud.google.com/apis/library/gmail.googleapis.com" target="_blank" rel="noopener" class="api-link">
        <span class="api-icon">✉️</span>
        <span>
          <strong>Gmail API</strong><br>
          <small>Required for sending email via Gmail</small>
        </span>
        <span class="api-arrow">&rarr;</span>
      </a>
    </div>
    <p class="hint">Only enable what you need. If you're using a different email provider, you can skip the Gmail API.</p>
  </div>
</div>

<!-- ── STEP 3 ─────────────────────────────────────────────── -->
<div class="walkthrough-step">
  <div class="step-number">3</div>
  <div class="step-body">
    <h3>Configure the OAuth consent screen</h3>
    <p>This is what users see when they connect their Google account.</p>
    <ol>
      <li>Go to <strong><a href="https://console.cloud.google.com/apis/credentials/consent" target="_blank" rel="noopener">APIs &amp; Services &rarr; OAuth consent screen</a></strong></li>
      <li>Choose <strong>External</strong> and click <strong>Create</strong></li>
      <li>Fill in:
        <ul>
          <li><strong>App name:</strong> Daily Schedule</li>
          <li><strong>User support email:</strong> your email address</li>
          <li><strong>Developer contact email:</strong> your email address</li>
        </ul>
      </li>
      <li>Click <strong>Save and Continue</strong></li>
      <li>On the <strong>Scopes</strong> page, click <strong>Add or Remove Scopes</strong> and add:
        <ul>
          <li><code>.../auth/calendar.readonly</code></li>
          <li><code>.../auth/gmail.send</code></li>
        </ul>
        Then click <strong>Update</strong> and <strong>Save and Continue</strong>
      </li>
      <li>On the <strong>Test users</strong> page, click <strong>Add Users</strong> and add the Google accounts that will connect to this app (your family's Gmail addresses)</li>
      <li>Click <strong>Save and Continue</strong> through to the end</li>
    </ol>
    <div class="callout">
      <strong>Why "External" and "Test users"?</strong> Google requires verification to publish OAuth apps broadly. For a private family app you don't need that — keeping it in "Testing" mode with your family's accounts added as test users works indefinitely.
    </div>
  </div>
</div>

<!-- ── STEP 4 ─────────────────────────────────────────────── -->
<div class="walkthrough-step">
  <div class="step-number">4</div>
  <div class="step-body">
    <h3>Create OAuth credentials</h3>
    <ol>
      <li>Go to <strong><a href="https://console.cloud.google.com/apis/credentials" target="_blank" rel="noopener">APIs &amp; Services &rarr; Credentials</a></strong></li>
      <li>Click <strong>+ Create Credentials &rarr; OAuth client ID</strong></li>
      <li>Choose <strong>Web application</strong></li>
      <li>Give it a name (e.g. <em>Daily Schedule</em>)</li>
      <li>Under <strong>Authorized redirect URIs</strong>, click <strong>Add URI</strong> and enter:<br>
        <code class="redirect-uri"><%= redirectUri %></code>
        <button type="button" class="btn btn-sm btn-ghost" onclick="navigator.clipboard.writeText('<%= redirectUri %>');this.textContent='Copied!'">Copy</button>
      </li>
      <li>Click <strong>Create</strong></li>
    </ol>
    <% if (isPrivateIp) { %>
    <div class="callout callout-warn">
      <strong>Private IP detected.</strong> Google does not allow private IP addresses (10.x, 192.168.x, 172.16–31.x) as redirect URIs.
      You have two options:
      <ol style="margin-top:8px;">
        <li><strong>Use a hostname instead of an IP.</strong> Add an entry to your router's DNS or your computer's <code>/etc/hosts</code> file mapping a name like <code>daily.home</code> to <code><%= new URL(redirectUri).hostname %></code>, then access the app via that hostname. The redirect URI will update automatically.</li>
        <li><strong>Set <code>GOOGLE_REDIRECT_URI</code></strong> in your <code>docker-compose.yml</code> to a publicly reachable URL (e.g. via Cloudflare Tunnel or a reverse proxy with a real domain), and register that URL in Google Cloud Console instead.</li>
      </ol>
    </div>
    <% } %>
    <p>A dialog will appear showing your <strong>Client ID</strong> and <strong>Client Secret</strong>. Copy both — you'll paste them below.</p>
  </div>
</div>

<!-- ── STEP 5 ─────────────────────────────────────────────── -->
<div class="walkthrough-step">
  <div class="step-number">5</div>
  <div class="step-body">
    <h3>Paste your credentials here</h3>
    <form method="POST" action="/setup/google-oauth" class="form">
      <input type="hidden" name="return_to" value="<%= returnTo %>">
      <div class="form-group">
        <label>Client ID <span class="hint">(ends in .apps.googleusercontent.com)</span></label>
        <input type="text" name="google_client_id"
          value="<%= config.google_client_id || '' %>"
          placeholder="123456789-abc….apps.googleusercontent.com"
          autocomplete="off" required>
      </div>
      <div class="form-group">
        <label>Client Secret</label>
        <input type="password" name="google_client_secret"
          value="<%= config.google_client_secret ? '••••••••' : '' %>"
          placeholder="GOCSPX-…"
          autocomplete="off" required>
        <% if (config.google_client_secret) { %>
          <p class="field-hint">Secret is set. Enter a new value to replace it.</p>
        <% } %>
      </div>
      <div class="form-actions">
        <button type="submit" class="btn btn-primary">Save &amp; Done</button>
        <a href="<%= returnTo %>" class="btn btn-ghost">Cancel</a>
      </div>
    </form>
  </div>
</div>

</div><!-- /max-width -->

<style>
.walkthrough-step {
  display: flex;
  gap: 20px;
  margin-bottom: 28px;
}
.step-number {
  flex-shrink: 0;
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: var(--navy);
  color: #fff;
  font-size: 14px;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 2px;
}
.step-body {
  flex: 1;
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 20px 24px;
}
.step-body h3 { margin: 0 0 12px; }
.step-body ol, .step-body ul { padding-left: 20px; margin: 8px 0; }
.step-body li { margin-bottom: 6px; line-height: 1.55; }
.step-body code {
  font-family: monospace;
  font-size: 13px;
  background: #f1ede4;
  padding: 2px 6px;
  border-radius: 3px;
}
.redirect-uri {
  display: inline-block;
  margin-right: 8px;
}
.api-links { display: flex; flex-direction: column; gap: 10px; margin: 12px 0; }
.api-link {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 16px;
  background: var(--cream);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  text-decoration: none;
  color: var(--text);
  transition: border-color 0.15s;
}
.api-link:hover { border-color: var(--navy); }
.api-icon { font-size: 20px; }
.api-arrow { margin-left: auto; color: var(--muted); }
.callout {
  margin-top: 14px;
  padding: 12px 16px;
  background: #eff6ff;
  border: 1px solid #bfdbfe;
  border-radius: var(--radius);
  font-size: 13px;
  color: #1e40af;
  line-height: 1.55;
}
.callout-warn {
  background: #fffbeb;
  border-color: #fcd34d;
  color: #92400e;
}
</style>

<%- include('_foot') %>
