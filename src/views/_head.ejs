<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — Daily Schedule</title>
  <meta name="csrf-token" content="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
  <script>(function(){var t=localStorage.getItem('ds-theme');if(t)document.documentElement.setAttribute('data-theme',t);})()</script>
  <link rel="stylesheet" href="/style.css">
  <style>:root { --navy: <%= branding.primary %>; --gold: <%= branding.accent %>; }</style>
  <script>function getCsrfToken(){return document.querySelector('meta[name="csrf-token"]')?.content||'';}</script>
</head>
<body>
<% var _p = currentPath || ''; %>
<nav class="nav">
  <a href="/setup" class="nav-brand">Daily Schedule</a>
  <div class="nav-links">

    <div class="nav-dropdown" id="nav-settings">
      <button class="btn-nav-dropdown <%= _p.startsWith('/setup/') && _p !== '/setup/recipients' ? 'active' : '' %>"
              onclick="toggleNavDropdown(event)">
        Settings <span style="font-size:10px;opacity:0.7;">▾</span>
      </button>
      <div class="nav-dropdown-menu">
        <a href="/setup/family"    class="<%= _p === '/setup/family'              ? 'nav-link-active' : '' %>">Family</a>
        <a href="/setup/calendars" class="<%= _p.startsWith('/setup/calendars')   ? 'nav-link-active' : '' %>">Calendars</a>
        <a href="/setup/email"     class="<%= _p === '/setup/email'               ? 'nav-link-active' : '' %>">Email</a>
        <a href="/setup/api-keys"  class="<%= _p === '/setup/api-keys'            ? 'nav-link-active' : '' %>">API Keys</a>
        <a href="/setup/blurbs"    class="<%= _p === '/setup/blurbs'              ? 'nav-link-active' : '' %>">AI Blurbs</a>
        <a href="/setup/webhooks"  class="<%= _p === '/setup/webhooks'            ? 'nav-link-active' : '' %>">Webhooks</a>
        <a href="/setup/storage"   class="<%= _p.startsWith('/setup/storage')     ? 'nav-link-active' : '' %>">Storage</a>
        <a href="/setup/branding"  class="<%= _p === '/setup/branding'            ? 'nav-link-active' : '' %>">Branding</a>
      </div>
    </div>

    <a href="/setup/recipients" class="<%= _p === '/setup/recipients' ? 'nav-link-active' : '' %>">Recipients</a>
    <a href="/newsletters"      class="<%= _p === '/newsletters'      ? 'nav-link-active' : '' %>">PDFs</a>
    <a href="/logs"             class="<%= _p === '/logs'             ? 'nav-link-active' : '' %>">Logs</a>
    <span class="nav-divider"></span>
    <button id="theme-toggle" class="btn-nav-theme" onclick="toggleTheme()"></button>
    <span class="nav-divider"></span>
    <a href="/auth/set-password" class="nav-link-muted">Password</a>
    <form method="POST" action="/auth/logout" style="display:inline;">
      <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
      <button type="submit" class="btn-nav-logout">Sign out</button>
    </form>
  </div>
</nav>
<main class="main">
