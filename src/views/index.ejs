<%- include('_head', { title: 'Dashboard' }) %>

<div class="page-header">
  <div>
    <h1>Daily Schedule</h1>
    <p class="subtitle">
      <% if (config.family_name) { %>
        <%= config.family_name %> Family &nbsp;&middot;&nbsp;
      <% } %>
      <% if (config.send_to) { %>
        Sending to <strong><%= config.send_to %></strong>
      <% } else { %>
        <span class="warn">Not configured yet</span>
      <% } %>
    </p>
  </div>
  <% if (config.setup_complete) { %>
    <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
      <input type="date" id="previewDate" style="padding:7px 10px;border:1px solid var(--border);border-radius:var(--radius);font-size:14px;background:#fff;" title="Preview date (defaults to tomorrow)">
      <button class="btn btn-primary" id="sendNowBtn">Send Now</button>
      <button class="btn btn-ghost" id="testSendBtn">Test Send…</button>
      <a href="#" target="_blank" class="btn btn-ghost" id="previewBtn">Preview</a>
      <a href="#" target="_blank" class="btn btn-ghost" id="pdfPreviewBtn"><%= config.html2pdf_api_key ? 'Preview PDF' : 'Preview PDF (no key)' %></a>
    </div>
    <!-- Test Send panel (hidden until button clicked) -->
    <div id="testSendPanel" style="display:none;margin-top:10px;padding:14px 16px;background:var(--cream);border:1px solid var(--border);border-radius:var(--radius);">
      <p style="margin:0 0 10px;font-size:13px;color:var(--muted);">
        Runs the full send pipeline — fetches calendar events, weather, generates PDF —
        but delivers only to the address below. Skips printer, storage upload, and webhooks.
        Subject is prefixed with <strong>[TEST]</strong>.
      </p>
      <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
        <input type="email" id="testSendEmail" placeholder="you@example.com"
          value="<%= config.send_to ? config.send_to.split(',')[0].trim() : '' %>"
          style="flex:1;min-width:220px;padding:7px 10px;border:1px solid var(--border);border-radius:var(--radius);font-size:14px;background:var(--white);">
        <button class="btn btn-primary" id="testSendConfirmBtn">Send Test</button>
        <button class="btn btn-ghost" onclick="document.getElementById('testSendPanel').style.display='none'">Cancel</button>
      </div>
      <div id="testSendResult" style="margin-top:8px;font-size:13px;display:none;"></div>
    </div>
  <% } %>
</div>

<% if (!config.setup_complete) { %>
  <div class="alert alert-info">
    <strong>Welcome!</strong> Complete setup to start sending your daily newsletter.
    <a href="/setup/family">Begin setup &rarr;</a>
  </div>
<% } %>

<div class="card-grid">
  <div class="card">
    <h3>Calendars</h3>
    <% if (calendars.length === 0) { %>
      <p class="muted">No calendars connected. <a href="/setup/calendars">Add one &rarr;</a></p>
    <% } else { %>
      <ul class="list">
        <% for (const cal of calendars) { %>
          <li><span class="badge badge-<%= cal.provider %>"><%= cal.provider %></span> <%= cal.name %></li>
        <% } %>
      </ul>
    <% } %>
  </div>

  <div class="card">
    <h3>Email</h3>
    <% if (emailAccount) { %>
      <p><span class="badge badge-<%= emailAccount.provider %>"><%= emailAccount.provider %></span>
      <%= emailAccount.credentials && (emailAccount.credentials.email || emailAccount.credentials.user) || 'Configured' %></p>
    <% } else { %>
      <p class="muted">No email configured. <a href="/setup/email">Set up &rarr;</a></p>
    <% } %>
  </div>

  <div class="card">
    <h3>Schedule</h3>
    <p>
      <% if (config.setup_complete) { %>
        Daily at <strong><span id="schedule-time" data-hour="<%= config.schedule_hour != null ? config.schedule_hour : 7 %>" data-minute="<%= config.schedule_minute != null ? config.schedule_minute : 0 %>"><%= config.schedule_hour != null ? config.schedule_hour : 7 %>:00</span></strong>
        &nbsp;(<%= config.timezone || 'America/New_York' %>)
      <% } else { %>
        <span class="muted">Not scheduled</span>
      <% } %>
    </p>
  </div>

  <div class="card">
    <h3>Branding</h3>
    <%
      const _primary = config.branding_primary_color || '#1a2e4a';
      const _accent  = config.branding_accent_color  || '#c9a96e';
    %>
    <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px;">
      <span style="display:inline-block;width:20px;height:20px;border-radius:4px;background:<%= _primary %>;border:1px solid rgba(0,0,0,0.1);"></span>
      <span style="display:inline-block;width:20px;height:20px;border-radius:4px;background:<%= _accent %>;border:1px solid rgba(0,0,0,0.1);"></span>
      <% if (config.branding_logo_url) { %>
        <span class="muted" style="font-size:12px;">Logo set</span>
      <% } %>
    </div>
    <p class="muted" style="font-size:12px;margin:0;"><a href="/setup/branding">Edit branding &rarr;</a></p>
  </div>
</div>

<div class="card">
  <h3>Recent Sends</h3>
  <% if (logs.length === 0) { %>
    <p class="muted">No sends yet.</p>
  <% } else { %>
    <table class="table">
      <thead><tr><th>Date</th><th>Status</th><th>Details</th><th>Sent At</th></tr></thead>
      <tbody>
        <% for (const log of logs) { %>
          <tr>
            <td><span class="fmt-date" data-date="<%= log.date %>"><%= log.date %></span></td>
            <td><span class="badge badge-<%= log.status %>"><%= log.status %></span></td>
            <td class="muted"><%= log.details || '—' %></td>
            <td class="muted"><span class="fmt-ts" data-ts="<%= log.sent_at %>"><%= log.sent_at %></span></td>
          </tr>
        <% } %>
      </tbody>
    </table>
  <% } %>
</div>

<script>
// Format newsletter date column: "2026-03-21" → "Sat, Mar 21"
document.querySelectorAll('.fmt-date').forEach(el => {
  const d = new Date(el.dataset.date + 'T12:00:00Z');
  el.textContent = d.toLocaleDateString(undefined, { weekday: 'short', month: 'short', day: 'numeric', timeZone: 'UTC' });
});

// Format sent-at column: "2026-03-20 22:04:44" (UTC) → local "Mar 20, 10:04 PM"
document.querySelectorAll('.fmt-ts').forEach(el => {
  const d = new Date(el.dataset.ts.replace(' ', 'T') + 'Z');
  el.textContent = d.toLocaleString(undefined, { month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' });
});

// Format schedule time: hour=21 minute=13 → "9:13 PM"
const schedEl = document.getElementById('schedule-time');
if (schedEl) {
  const h = parseInt(schedEl.dataset.hour,   10);
  const m = parseInt(schedEl.dataset.minute, 10) || 0;
  const d = new Date(); d.setHours(h, m, 0, 0);
  schedEl.textContent = d.toLocaleTimeString(undefined, { hour: 'numeric', minute: '2-digit' });
}

// Preview date picker — defaults to tomorrow
(function () {
  const dateInput = document.getElementById('previewDate');
  if (!dateInput) return;
  const tomorrow = new Date();
  tomorrow.setDate(tomorrow.getDate() + 1);
  const iso = tomorrow.toISOString().substring(0, 10);
  dateInput.value = iso;

  function previewUrl(view) {
    const date = dateInput.value || iso;
    return `/api/preview?view=${view}&date=${date}`;
  }

  const previewBtn    = document.getElementById('previewBtn');
  const pdfPreviewBtn = document.getElementById('pdfPreviewBtn');

  function updateLinks() {
    if (previewBtn)    previewBtn.href    = previewUrl('email');
    if (pdfPreviewBtn) pdfPreviewBtn.href = previewUrl('pdf');
  }

  dateInput.addEventListener('change', updateLinks);
  updateLinks();
})();

document.getElementById('sendNowBtn')?.addEventListener('click', async () => {
  const btn = document.getElementById('sendNowBtn');
  btn.disabled = true;
  btn.textContent = 'Sending…';
  try {
    const res  = await fetch('/api/send-now', { method: 'POST' });
    const data = await res.json();
    btn.textContent = data.ok ? 'Started!' : 'Error';
  } catch {
    btn.textContent = 'Error';
  }
  setTimeout(() => { btn.disabled = false; btn.textContent = 'Send Now'; }, 3000);
});

document.getElementById('testSendBtn')?.addEventListener('click', () => {
  const panel = document.getElementById('testSendPanel');
  panel.style.display = panel.style.display === 'none' ? '' : 'none';
  document.getElementById('testSendResult').style.display = 'none';
});

document.getElementById('testSendConfirmBtn')?.addEventListener('click', async () => {
  const email  = document.getElementById('testSendEmail').value.trim();
  const btn    = document.getElementById('testSendConfirmBtn');
  const result = document.getElementById('testSendResult');

  if (!email) { alert('Enter an email address'); return; }

  btn.disabled = true;
  btn.textContent = 'Sending…';
  result.style.display = 'none';

  try {
    const res  = await fetch('/api/send-test', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify({ email }),
    });
    const data = await res.json();
    result.style.display = '';
    result.style.color = data.ok ? 'var(--text)' : 'var(--error, #c00)';
    result.textContent = data.ok ? data.message : ('Error: ' + (data.error || 'unknown'));
  } catch (err) {
    result.style.display = '';
    result.style.color = 'var(--error, #c00)';
    result.textContent = 'Request failed: ' + err.message;
  }

  btn.disabled = false;
  btn.textContent = 'Send Test';
});
</script>

<%- include('_foot') %>
