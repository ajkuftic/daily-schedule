<%- include('_head', { title: 'Recipients' }) %>

<h1>Recipients</h1>
<p class="subtitle">Manage who receives the daily newsletter and whether they get the PDF attachment.</p>

<% if (flash.saved)   { %><div class="alert alert-success">Saved.</div><% } %>
<% if (flash.deleted) { %><div class="alert alert-success">Recipient removed.</div><% } %>
<% if (flash.error)   { %><div class="alert alert-error">Error: <%= flash.error %></div><% } %>

<% if (recipients.length > 0) { %>
<form method="POST" action="/setup/recipients/update-all" class="form">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
  <div class="card" style="margin-bottom:24px;">
    <h3>Current Recipients</h3>
    <table class="table">
      <thead><tr><th>Email</th><th>Name</th><th>PDF</th><th>Active</th><th></th></tr></thead>
      <tbody>
        <% for (const r of recipients) { %>
          <tr>
            <td>
              <input type="hidden" name="rid" value="<%= r.id %>">
              <input type="email" name="email_<%= r.id %>" value="<%= r.email %>" required style="width:100%;min-width:180px;">
            </td>
            <td><input type="text" name="name_<%= r.id %>" value="<%= r.name || '' %>" placeholder="Optional name" style="width:100%;"></td>
            <td style="text-align:center;">
              <input type="checkbox" name="include_pdf_<%= r.id %>" value="1" <%= r.include_pdf ? 'checked' : '' %>>
            </td>
            <td style="text-align:center;">
              <input type="checkbox" name="active_<%= r.id %>" value="1" <%= r.active ? 'checked' : '' %>>
            </td>
            <td style="white-space:nowrap;">
              <button type="button" class="btn btn-sm btn-danger"
                onclick="deleteRecipient(<%= r.id %>)">Remove</button>
            </td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
  <div class="form-actions">
    <button type="submit" class="btn btn-primary">Save All</button>
    <a href="/setup" class="btn btn-ghost">Back to Dashboard</a>
  </div>
</form>
<% } else { %>
<div class="alert alert-info">No recipients yet. Add one below.</div>
<% } %>

<div class="card">
  <h3>Add Recipient</h3>
  <form method="POST" action="/setup/recipients/add" class="form">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <div class="form-row">
      <div class="form-group">
        <label>Email <span class="hint">(required)</span></label>
        <input type="email" name="email" placeholder="person@example.com" required>
      </div>
      <div class="form-group">
        <label>Name <span class="hint">(optional)</span></label>
        <input type="text" name="name" placeholder="Jane">
      </div>
    </div>
    <div class="form-group">
      <label style="display:flex;align-items:center;gap:8px;cursor:pointer;">
        <input type="checkbox" name="include_pdf" value="1" checked>
        Include PDF attachment
      </label>
    </div>
    <div class="form-actions">
      <button type="submit" class="btn btn-primary">Add Recipient</button>
    </div>
  </form>
</div>

<div class="card" style="margin-top:24px;">
  <h3>Delivery Schedule</h3>
  <p class="muted">Choose when to send the daily newsletter.</p>
  <form method="POST" action="/setup/schedule" class="form" style="margin-top:16px;">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <div class="form-group">
      <label>Send Time</label>
      <%
        const _h = parseInt(config.schedule_hour ?? 7, 10);
        const _m = parseInt(config.schedule_minute ?? 0, 10);
        const _period = _h < 12 ? 'AM' : 'PM';
        const _display12 = _h === 0 ? 12 : _h > 12 ? _h - 12 : _h;
        const _currentVal = `${_display12}:${String(_m).padStart(2,'0')} ${_period}`;
      %>
      <input type="text" name="send_time" id="send_time"
             value="<%= _currentVal %>"
             placeholder="e.g. 9:00 PM or 21:00"
             autocomplete="off"
             style="max-width:200px;">
      <p class="field-hint">Times are in <%= config.timezone || 'America/New_York' %>. The newsletter always covers <em>tomorrow's</em> events — sending at night gives you a preview before bed.</p>
    </div>
    <button type="submit" class="btn btn-primary">Save &amp; Activate</button>
  </form>
</div>

<%- include('_setup-nav', { prev: '/setup/blurbs', prevLabel: 'AI Blurbs', next: '/setup/webhooks', nextLabel: 'Webhooks' }) %>

<script>
function deleteRecipient(id) {
  if (!confirm('Remove this recipient?')) return;
  var form = document.createElement('form');
  form.method = 'POST';
  form.action = '/setup/recipients/' + id + '/delete';
  var csrf = document.createElement('input');
  csrf.type = 'hidden';
  csrf.name = '_csrf';
  csrf.value = getCsrfToken();
  form.appendChild(csrf);
  document.body.appendChild(form);
  form.submit();
}
</script>

<%- include('_foot') %>
