# Daily Schedule — Environment Variables
# Copy to .env and fill in your values

# Session secret — generate with: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-random-secret

# Data directory (SQLite database and uploads)
DATA_DIR=./data

# Port
PORT=3000

# Google OAuth (for Google Calendar + Gmail)
# Create at console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Microsoft OAuth (for Outlook calendar + email)
# Create at portal.azure.com → App registrations
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:3000/auth/microsoft/callback
