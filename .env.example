# Daily Schedule — Environment Variables
# Copy to .env and fill in your values

# Session secret — generate with: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-random-secret

# Data directory (SQLite database and uploads)
DATA_DIR=./data

# Port (HTTP, used when not running behind Caddy)
PORT=3000

# ── HTTPS / Caddy ─────────────────────────────────────────────────────────────
# Required when using the https profile: docker compose --profile https up -d
# Must be a domain pointed at this machine's public IP, with ports 80 and 443
# forwarded from your router. Caddy handles cert provisioning automatically.
#DOMAIN=daily.example.com
